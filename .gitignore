# -*- mode: gitignore; -*-
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
recentf
.\#*

# Org-mode
.org-id-locations
*_archive

# flymake-mode
*_flymake.*

# eshell files
/eshell/history
/eshell/lastdir

# elpa packages
/elpa/
/elpa.emacs27.bak/

# config backups from the modernization
/init.el.bak
/lisp.bak/

# pinned third-party checkouts (reproducible; see scripts/ + SETUP.md)
/site-lisp/

# claude-code-ide checkout (user-provided; loaded by lisp/init-claude.el).
# It is its own git checkout under local/, so keep it out of this repo.
/tmp/
/local/claude-code-ide/

# savehist runtime file
/history

# native-comp / eln cache
/eln-cache/

# reftex files
*.rel

# AUCTeX auto folder
/auto/

# cask packages
.cask/
dist/

# Flycheck
flycheck_*.el

# server auth directory
/server/

# projectiles files
projectile*
.projectile

# directory configuration
.dir-locals.el

# ebook marks
nov-places

# vim swapfiles (oops)
*.swp

# web mode
/request
/url

# bm mode
bm-repository
.cache/
.lsp-session-v1
elpy/
session.*
